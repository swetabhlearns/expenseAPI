{
  "name": "expenseclaim-node-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts",
    "seed:demo-users": "tsx src/migration/seedDemoUsers.ts",
    "prune:demo-employees": "tsx src/migration/pruneDemoEmployees.ts",
    "fix:claim-dates-local": "tsx src/migration/fixClaimDatesToLocal.ts",
    "migrate:backfill": "tsx src/migration/backfill.ts",
    "migrate:sync": "tsx src/migration/syncIncremental.ts",
    "migrate:reconcile": "tsx src/migration/reconcile.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.6.2",
    "fastify-plugin": "^5.1.0",
    "firebase-admin": "^13.6.0",
    "mongoose": "^8.20.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3"
  }
}
